{
  "name": "retend-server",
  "version": "0.0.24",
  "private": false,
  "description": "Static site generation for the retend UI framework.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/client-only.d.ts",
      "import": "./dist/client-only.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./v-dom": {
      "types": "./dist/v-dom/index.d.ts",
      "import": "./dist/v-dom/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.js"
  },
  "dependencies": {
    "acorn": "^8.14.1",
    "domhandler": "^5.0.3",
    "estree-walker": "^3.0.3",
    "htmlparser2": "^10.0.0",
    "magic-string": "^0.30.17",
    "oxc-parser": "^0.115.0",
    "oxc-walker": "^0.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "retend": "workspace:*",
    "retend-web": "workspace:*",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  },
  "peerDependencies": {
    "retend": "*",
    "retend-web": "*",
    "vite": "*"
  }
}
