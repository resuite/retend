{
  "name": "retend-utils",
  "version": "0.0.26",
  "private": false,
  "description": "A collection of utility functions for Retend.",
  "keywords": [
    "javascript",
    "jsx",
    "pwa",
    "web"
  ],
  "homepage": "https://github.com/resuite/retend#readme",
  "bugs": {
    "url": "https://github.com/resuite/retend/issues"
  },
  "license": "MIT",
