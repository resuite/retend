{
  "name": "retend-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/logs vite --port 3000",
    "build": "pnpm -C .. build && WRANGLER_LOG_PATH=.wrangler/logs tsc --noEmit && WRANGLER_LOG_PATH=.wrangler/logs vite build",
    "build-docs": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && WRANGLER_LOG_PATH=.wrangler/logs npx wrangler deploy"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "remark-gfm": "^4.0.1",
    "retend": "workspace:*",
    "retend-server": "workspace:*",
    "retend-utils": "workspace:*",
    "retend-web": "workspace:*",
    "retend-web-devtools": "workspace:*",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.12.2",
    "@types/node": "^22.7.5",
    "typescript": "^5.8.2",
    "vite": "^6.4.1"
  }
}
